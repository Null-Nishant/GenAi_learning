      "updated": 1783777080784,
      "link": null,
      "locked": false,
      "text": "client send the request to server then server send the request to the llm (along with the list of function \nthat are avialable in the server) then LLM predict which api should be called for the request then the result \nis send to the server back and then the api is called and the result is send to the llm and final result is send\n to the client",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "client send the request to server then server send the request to the llm (along with the list of function \nthat are avialable in the server) then LLM predict which api should be called for the request then the result \nis send to the server back and then the api is called and the result is send to the llm and final result is send\n to the client",
      "autoResize": true,
      "lineHeight": 1.25
    },
